use v6.d;
use lib 'lib';
use lib 'specs/lib';
use Models::User;
use Models::Page;
use Test;

plan 3;

%*ENV<DISABLE-SQL-LOG> = True;

my $user = User.create({fname => 'Greg', lname => 'Donald'});
ok $user.is-valid;

my $page = Page.create({:$user, name => 'Raku'});
ok $page.is-valid;
ok $page.user_id == $user.id;

Page.destroy-all;
User.destroy-all;
