use v6.d;
use lib 'lib';
use lib 'specs/lib';
use ORM::ActiveRecord::DB;
use Models::User;
use Models::Page;
use Test;

plan 10;

%*ENV<DISABLE-SQL-LOG> = True;

DB.shared.delete-records(:table('pages'), :where({}));
DB.shared.delete-records(:table('users'), :where({}));

# autosave: True saves a new parent before the child
my $new-parent = User.new(:id(0), :record({attrs => {fname => 'Parent'}}));
is $new-parent.id, 0, 'parent starts unsaved';
my $child = Page.create({name => 'C', autosave-user => $new-parent});
ok $new-parent.id > 0, 'autosave: True saved the new parent';
is $child.attrs<user_id>, $new-parent.id,
  'foreign-key column points to the saved parent';

# autosave on an existing parent re-saves it (Rails parity)
my $loaded = User.find($new-parent.id);
$loaded.attrs<fname> = 'Renamed';
Page.create({name => 'C2', autosave-user => $loaded});
my $reloaded = User.find($new-parent.id);
is $reloaded.attrs<fname>, 'Renamed',
  'autosave: True on an existing parent persists changes';

# Cascade validation: child rolls up parent's errors
DB.shared.delete-records(:table('pages'), :where({}));
DB.shared.delete-records(:table('users'), :where({}));

my $invalid-parent = User.new(:id(0), :record({attrs => {fname => ''}}));
nok $invalid-parent.is-valid, 'parent fails its own presence validation';

my $cv-child = Page.new(:id(0), :record({
  attrs => {name => 'X', autosave-user => $invalid-parent},
}));
nok $cv-child.is-valid,
  'child with validate: True fails when parent invalid';
ok $cv-child.errors.errors.elems > 0,
  'child accumulates an error from the parent';
like $cv-child.errors.errors.first.message, /'is invalid'/,
  'cascaded error reads "is invalid"';

# A valid parent passes through validate: True
my $good-parent = User.create({fname => 'OK'});
my $good-child = Page.new(:id(0), :record({
  attrs => {name => 'Y', autosave-user => $good-parent},
}));
ok $good-child.is-valid,
  'child with validate: True passes when parent is valid';
ok $good-child.save, 'child saves under validate: True';

DB.shared.delete-records(:table('pages'), :where({}));
DB.shared.delete-records(:table('users'), :where({}));
