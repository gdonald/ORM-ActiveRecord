use v6.d;
use lib 'lib';
use lib 'specs/lib';
use Validation::PresenceOnCreate;
use Test;

plan 9;

%*ENV<DISABLE-SQL-LOG> = True;

my @errors;
my $user;

$user = User.create();
ok $user.is-invalid;
ok $user.errors.fname[0] eq 'must be present';

$user = User.create({});
ok $user.is-invalid;
ok $user.errors.fname[0] eq 'must be present';

$user = User.create({fname => 'Greg'});
ok $user.is-valid;
nok $user.errors.fname[0];

$user.fname = Nil;
ok $user.save;
ok $user.is-valid;
nok $user.errors.fname[0];

User.destroy-all;
