use v6.d;
use lib 'lib';
use lib 'specs/lib';
use Validation::UniquenessConditions;
use Test;

plan 7;

%*ENV<DISABLE-SQL-LOG> = True;

Voter.destroy-all;

Voter.create({username => 'inactive_dupe', is_active => False, tenant_id => 1});
my $ok = Voter.build({username => 'inactive_dupe', is_active => True, tenant_id => 1});
ok $ok.is-valid, 'inactive duplicate is allowed because conditions limit lookup to is_active=True';

Voter.create({username => 'active_user', is_active => True, tenant_id => 1});
my $clash = Voter.build({username => 'active_user', is_active => True, tenant_id => 2});
ok $clash.is-invalid, 'duplicate within active scope fails uniqueness';
ok $clash.errors.username[0] eq 'must be unique', 'reports must be unique';

Voter.destroy-all;
Donor.create({username => 'shared', is_active => True, tenant_id => 1});

my $other-tenant = Donor.build({username => 'shared', is_active => True, tenant_id => 2});
ok $other-tenant.is-valid, 'scope keeps name unique per tenant';

my $same-tenant = Donor.build({username => 'shared', is_active => True, tenant_id => 1});
ok $same-tenant.is-invalid, 'same name + same tenant + active fails';

Donor.create({username => 'inactive_in_scope', is_active => False, tenant_id => 1});
my $allow-inactive-dup = Donor.build({username => 'inactive_in_scope', is_active => False, tenant_id => 1});
ok $allow-inactive-dup.is-valid, 'inactive records ignored by conditions clause';

my $promote = Donor.build({username => 'inactive_in_scope', is_active => True, tenant_id => 1});
ok $promote.is-valid, 'no active record yet for tenant - validates';

Donor.destroy-all;
