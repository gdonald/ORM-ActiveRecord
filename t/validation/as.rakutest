
use v6.d;
use lib 'lib';
use ORM::ActiveRecord::Model;
use Test;

class AsPhevent is Model {
  method table-name { 'phevents' }

  submethod BUILD {
    self.validate: 'max_score', { :presence, as => 'Maximum Score', message => '{attribute} must be present' }
  }
}

class AsPhevent2 is Model {
  method table-name { 'phevents' }

  submethod BUILD {
    self.validate: 'score', { numericality => { gte => 10 }, as => 'Player Score', message => '{attribute} must be at least {value}' }
  }
}

plan 6;

%*ENV<DISABLE-SQL-LOG> = True;

AsPhevent.destroy-all;

my $ev = AsPhevent.build({name => 'A', score => 5, max_score => 0});
ok $ev.is-invalid, 'fails when max_score is missing';
ok $ev.errors.max_score[0] eq 'Maximum Score must be present',
  'as: overrides {attribute} in template';

$ev = AsPhevent2.build({name => 'A', score => 1, max_score => 1});
ok $ev.is-invalid, 'fails when score < gte threshold';
ok $ev.errors.score[0] eq 'Player Score must be at least 10',
  'as: overrides {attribute} in numericality message';

$ev = AsPhevent.build({name => 'A', score => 5, max_score => 99});
ok $ev.is-valid, 'no error when valid';
nok $ev.errors.max_score, 'no error on errors object when valid';

AsPhevent.destroy-all;
