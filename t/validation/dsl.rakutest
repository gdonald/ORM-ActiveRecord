use v6.d;
use lib 'lib';
use lib 'specs/lib';
use Validation::Dsl;
use Test;

plan 8;

%*ENV<DISABLE-SQL-LOG> = True;

Carnival.destroy-all;

my $m = Carnival.build({name => '', score => 0, max_score => 0});
ok $m.is-invalid, 'all three fail validation';
ok $m.errors.name.elems == 2, 'aggregated declaration produces presence+length errors for name';
ok $m.errors.score[0] eq 'must be present', 'shared params apply per field (score)';
ok $m.errors.max_score[0] eq 'must be present', 'shared params apply per field (max_score)';

$m = Carnival.build({name => 'OK', score => 10, max_score => 20});
ok $m.is-valid, 'all fields present and within length';

$m = Carnival.build({name => 'Z', score => 1, max_score => 1});
ok $m.is-invalid, 'short name fails length';
ok $m.errors.name[0] eq 'at least 2 characters required', 'length min message';

$m = Carnival.build({name => 'WAY-TOO-LONG', score => 1, max_score => 1});
$m.is-invalid;
ok $m.errors.name[0] eq 'only 8 characters allowed', 'length max message';

Carnival.destroy-all;
