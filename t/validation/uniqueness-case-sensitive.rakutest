use v6.d;
use lib 'lib';
use lib 'specs/lib';
use Validation::UniquenessCaseSensitive;
use Test;

plan 6;

%*ENV<DISABLE-SQL-LOG> = True;

Patron.destroy-all;

my $u = Patron.create({username => 'Alfred'});
ok $u.is-valid, 'first user created';

my $clash = Patron.build({username => 'alfred'});
ok $clash.is-invalid, 'case-sensitive => False catches different-case dup';
ok $clash.errors.username[0] eq 'must be unique', 'reports must be unique';

my $cs-clash = Subscriber.build({username => 'alfred'});
ok $cs-clash.is-valid, 'case-sensitive => True allows different-case value';

my $default-clash = Visitor.build({username => 'alfred'});
ok $default-clash.is-valid, 'default uniqueness is case-sensitive';

my $exact-clash = Visitor.build({username => 'Alfred'});
ok $exact-clash.is-invalid, 'exact match still fails default uniqueness';

Patron.destroy-all;
