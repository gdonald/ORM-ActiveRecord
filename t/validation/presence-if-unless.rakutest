use v6.d;
use lib 'lib';
use lib 'specs/lib';
use Validation::PresenceIfUnless;
use Test;

plan 5;

%*ENV<DISABLE-SQL-LOG> = True;

my $book = Book.build;
nok $book.is-valid;

ok $book.errors.title[0] eq 'must be present';
nok $book.errors.pages;
nok $book.errors.sentences;
ok $book.errors.words[0] eq 'must be present';

Book.destroy-all;
