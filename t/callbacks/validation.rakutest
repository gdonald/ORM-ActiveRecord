use v6.d;
use lib 'lib';
use lib 'specs/lib';
use Callbacks::Validation;
use Test;

plan 5;

%*ENV<DISABLE-SQL-LOG> = True;

Client.destroy-all;

{
  @Callbacks::Validation::events = ();
  my $c = Client.build({ email => 'fred@aol.com' });
  $c.is-valid;
  is-deeply @Callbacks::Validation::events, ['before', 'after'], 'before/after-validation fire on is-valid';
}

{
  @Callbacks::Validation::events = ();
  my $c = Client.build({ email => '' });
  ok $c.is-invalid, 'invalid record is invalid';
  is-deeply @Callbacks::Validation::events, ['before', 'after'], 'callbacks fire even when invalid';
}

{
  @Callbacks::Validation::events = ();
  my $c = Client.create({ email => 'wilma@aol.com' });
  ok $c.id != 0, 'record was created';
  ok @Callbacks::Validation::events.grep('before').elems >= 1 && @Callbacks::Validation::events.grep('after').elems >= 1,
     'validation callbacks fire during save';
}

Client.destroy-all;
