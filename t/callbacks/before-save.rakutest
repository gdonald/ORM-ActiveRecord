use v6.d;
use lib 'lib';
use lib 'specs/lib';
use Callbacks::BeforeSave;
use Test;

plan 2;

%*ENV<DISABLE-SQL-LOG> = True;

my $client = Client.create({ email => 'Fred@AOL.com' });
ok $client.email eq 'fred@aol.com';

$client.email = 'BARNEY@compuserve.NET';
$client.save;
ok $client.email eq 'barney@compuserve.net';

Client.destroy-all;
