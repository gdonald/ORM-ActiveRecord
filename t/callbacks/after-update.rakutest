use v6.d;
use lib 'lib';
use lib 'specs/lib';
use Callbacks::AfterUpdate;
use Models::Log;
use Test;

plan 2;

%*ENV<DISABLE-SQL-LOG> = True;

my $client = Client.create({ email => 'fred@aol.com' });
ok Log.count == 0;

$client.email = 'barney@compuserve.net';
$client.save;
ok Log.count == 1;

Client.destroy-all;
Log.destroy-all;
